    "mysql2": "^3.6.5",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "joi": "^17.11.0",
    "multer": "^1.4.5-lts.1",
    "winston": "^3.11.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.1.4",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.0",
    "moment": "^2.29.4",
    "@aws-sdk/client-s3": "3.525.0",
    "@aws-sdk/client-secrets-manager": "3.525.0",
    "@aws-sdk/client-ssm": "3.525.0",
