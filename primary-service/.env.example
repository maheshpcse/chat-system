# Primary Service Environment Configuration

# Application
APP_NAME=ChatPrimaryService
APP_PORT=3000
APP_ENV=development
APP_VERSION=1.0.0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=chat_system
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_password
MYSQL_CONNECTION_LIMIT=20
MYSQL_QUEUE_LIMIT=0

# MongoDB Configuration (Analytics Service Connection)
MONGO_URI=mongodb://localhost:27017/chat_analytics

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=chat:

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=chat-uploads-bucket
AWS_SECRET_NAME=chat/production/secrets
AWS_PARAMETER_NAME=/chat/production/config

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/zip

# Socket.IO Configuration
SOCKET_CORS_ORIGIN=http://localhost:4200
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# CORS
CORS_ORIGIN=http://localhost:4200
CORS_METHODS=GET,POST,PUT,DELETE,PATCH

# Bcrypt
BCRYPT_SALT_ROUNDS=12
